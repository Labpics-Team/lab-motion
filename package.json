{
  "name": "@labpics/motion",
  "version": "1.0.0",
  "private": false,
  "description": "Dependency-free motion engine (spring solver + declarative API).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./easing": {
      "types": "./dist/easing/index.d.ts",
      "import": "./dist/easing/index.js",
      "require": "./dist/easing/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./svelte": {
      "types": "./dist/svelte/index.d.ts",
      "import": "./dist/svelte/index.js",
      "require": "./dist/svelte/index.cjs"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.js",
      "require": "./dist/vue/index.cjs"
    },
    "./value": {
      "types": "./dist/value/index.d.ts",
      "import": "./dist/value/index.js",
      "require": "./dist/value/index.cjs"
    },
    "./driver": {
      "types": "./dist/driver/index.d.ts",
      "import": "./dist/driver/index.js",
      "require": "./dist/driver/index.cjs"
    },
    "./stagger": {
      "types": "./dist/stagger/index.d.ts",
      "import": "./dist/stagger/index.js",
      "require": "./dist/stagger/index.cjs"
    },
    "./timeline": {
      "types": "./dist/timeline/index.d.ts",
      "import": "./dist/timeline/index.js",
      "require": "./dist/timeline/index.cjs"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "size": "node scripts/size-gate.mjs"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "svelte": ">=4.0.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "svelte": { "optional": true },
    "vue": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "@types/react": "18.3.12",
    "react": "18.3.1",
    "svelte": "4.2.19",
    "tsup": "8.3.6",
    "typescript": "5.7.3",
    "vitest": "2.1.8",
    "vue": "3.4.38"
  }
}
