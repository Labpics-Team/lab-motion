{
  "name": "@labpics/motion",
  "version": "1.0.0",
  "private": false,
  "description": "Dependency-free motion engine (spring solver + declarative API).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./easing": {
      "types": "./dist/easing/index.d.ts",
      "import": "./dist/easing/index.js",
      "require": "./dist/easing/index.cjs"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "tsup": "8.3.6",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
